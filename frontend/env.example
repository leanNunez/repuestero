# Plantilla de entorno del frontend. Copiar a frontend/.env.local (gitignoreado) y completar.
#   cp frontend/env.example frontend/.env.local

# URL del backend. En local: http://localhost:8000. En prod: la URL de Render.
VITE_API_URL=http://localhost:8000

# Supabase Auth (Project Settings → API en el dashboard de Supabase).
# La anon key es PÚBLICA — es segura para el front. NUNCA pongas acá la service_role key.
VITE_SUPABASE_URL=https://TU-PROYECTO.supabase.co
VITE_SUPABASE_ANON_KEY=
