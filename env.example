# Plantilla de variables de entorno.
# Copiar a .env (que está gitignoreado) y completar. NUNCA commitear .env.
#   cp env.example .env

# --- Base de datos ---
# Conexión que usa la APP. Este rol DEBE ser NOSUPERUSER y SIN BYPASSRLS.
# Si la app se conecta como postgres/service_role, las políticas RLS NO se aplican
# y el aislamiento multi-tenant es decorativo. Ver docs/blueprint.md §4.3.
DATABASE_URL=postgresql+psycopg://app_user:CAMBIAME@localhost:5432/repuestos

# Conexión que usa ALEMBIC (owner del esquema, puede crear tablas y políticas).
MIGRATIONS_DATABASE_URL=postgresql+psycopg://postgres:CAMBIAME@localhost:5432/repuestos

# Conexión READ-ONLY que usa el ASISTENTE NL2SQL. Rol app_readonly: NOSUPERUSER, sin BYPASSRLS,
# con SOLO SELECT. El SQL que genera el LLM corre acá → aunque genere un DELETE, la base lo rechaza.
DATABASE_READONLY_URL=postgresql+psycopg://app_readonly:CAMBIAME@localhost:5432/repuestos

# --- Supabase Auth ---
SUPABASE_URL=https://TU-PROYECTO.supabase.co

# Proyectos nuevos (claves asimétricas ES256/RS256): validación por JWKS.
SUPABASE_JWKS_URL=https://TU-PROYECTO.supabase.co/auth/v1/.well-known/jwks.json

# Proyectos legacy (HS256): secreto simétrico. Dejar vacío si usás JWKS.
SUPABASE_JWT_SECRET=

SUPABASE_JWT_AUDIENCE=authenticated

# --- Asistente conversacional (NL2SQL) ---
# Groq es el LLM primario; OpenAI el fallback automático si Groq falla o el SQL no valida.
GROQ_API_KEY=
OPENAI_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile
OPENAI_MODEL=gpt-4o-mini
# Techos de seguridad del SQL del asistente.
ASISTENTE_MAX_FILAS=200
ASISTENTE_TIMEOUT_MS=5000

# --- Ingesta visual (cargar un remito desde una foto) ---
# Usa OPENAI_MODEL, no GROQ_MODEL: la visión necesita un modelo multimodal y
# llama-3.3-70b-versatile es text-only. Sin OPENAI_API_KEY esta feature no funciona
# (y no hay proveedor de respaldo).
INGESTA_MAX_IMAGEN_MB=8
INGESTA_MAX_RENGLONES=50
# Debajo de esta confianza el renglón se marca para revisión. Hint de UI, no un gate.
INGESTA_UMBRAL_CONFIANZA=0.75
# Timeout de la llamada de visión (tarda segundos, no ms, como el resto).
INGESTA_TIMEOUT_MS=30000

# --- App ---
# CORS: en producción NUNCA "*". Lista separada por comas de orígenes permitidos.
ALLOWED_ORIGINS=*
ENV=dev
