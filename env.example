# Plantilla de variables de entorno.
# Copiar a .env (que está gitignoreado) y completar. NUNCA commitear .env.
#   cp env.example .env

# --- Base de datos ---
# Conexión que usa la APP. Este rol DEBE ser NOSUPERUSER y SIN BYPASSRLS.
# Si la app se conecta como postgres/service_role, las políticas RLS NO se aplican
# y el aislamiento multi-tenant es decorativo. Ver docs/blueprint.md §4.3.
DATABASE_URL=postgresql+psycopg://app_user:CAMBIAME@localhost:5432/repuestos

# Conexión que usa ALEMBIC (owner del esquema, puede crear tablas y políticas).
MIGRATIONS_DATABASE_URL=postgresql+psycopg://postgres:CAMBIAME@localhost:5432/repuestos

# --- Supabase Auth ---
SUPABASE_URL=https://TU-PROYECTO.supabase.co

# Proyectos nuevos (claves asimétricas ES256/RS256): validación por JWKS.
SUPABASE_JWKS_URL=https://TU-PROYECTO.supabase.co/auth/v1/.well-known/jwks.json

# Proyectos legacy (HS256): secreto simétrico. Dejar vacío si usás JWKS.
SUPABASE_JWT_SECRET=

SUPABASE_JWT_AUDIENCE=authenticated

# --- App ---
ENV=dev
